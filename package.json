{
  "name": "environment_status",
  "version": "1.0.0",
  "description": "Visualise Application Feature status & Uptime in your Environments",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test:ui": "playwright test --config=playwright.config.js --project=\"UI Tests\" --project=\"Collections UI Tests\"",
    "test:api": "playwright test --config=playwright.config.js --project=\"API Tests\" --project=\"Collections API Tests\"",
    "test:supertest": "mocha tests/supertest/collections-supertest.test.js --timeout 10000 --exit",
    "test:bruno": "cd tests/bruno/collections-api && bru run --env dev"
  },
  "keywords": [],
  "author": "Jim O'Brien",
  "license": "ISC",
  "dependencies": {
    "@influxdata/influxdb3-client": "^0.8.0",
    "@usebruno/cli": "^1.40.0",
    "body-parser": "^1.20.4",
    "cron": "^3.5.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.2",
    "newman": "^6.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "mochawesome": "^7.1.4",
    "supertest": "^6.3.4",
    "wait-on": "^8.0.5"
  }
